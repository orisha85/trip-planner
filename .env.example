# Copy to .env.local and fill in values.

# Postgres connection string (Vercel Postgres / Neon / any Postgres)
POSTGRES_URL="postgresql://user:password@host:5432/trip_organizer"

# Vercel Blob (auto-populated when you add the Blob integration on Vercel)
BLOB_READ_WRITE_TOKEN=""

# bcrypt hash of the shared password — generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
APP_PASSWORD_HASH=""

# 32+ byte random string for signing the session cookie — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Trip metadata shown in the header
TRIP_TITLE="France + Spain 2026"
TRIP_START="2026-07-31"
TRIP_END="2026-08-24"
HOME_CURRENCY="CAD"
